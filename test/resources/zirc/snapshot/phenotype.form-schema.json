{
  "schema" : {
    "properties" : {
      "description" : {
        "maxLength" : 5000,
        "title" : "Description",
        "type" : [ "string", "null" ]
      },
      "hpfEnd" : {
        "title" : "End (hpf)",
        "type" : [ "number", "null" ]
      },
      "hpfStart" : {
        "title" : "Start (hpf)",
        "type" : [ "number", "null" ]
      },
      "nonMendelianComment" : {
        "maxLength" : 5000,
        "title" : "Non-Mendelian comment",
        "type" : [ "string", "null" ]
      },
      "nonMendelianPercentage" : {
        "title" : "Non-Mendelian %",
        "type" : [ "number", "null" ]
      },
      "segregation" : {
        "items" : {
          "type" : "string"
        },
        "title" : "Segregation",
        "type" : "array"
      },
      "stage" : {
        "maxLength" : 255,
        "title" : "Stage",
        "type" : [ "string", "null" ]
      },
      "type" : {
        "items" : {
          "type" : "string"
        },
        "title" : "Phenotype type",
        "type" : "array"
      },
      "zfinImagePermission" : {
        "title" : "ZFIN image permission",
        "type" : [ "boolean", "null" ]
      },
      "zircImagePermission" : {
        "title" : "ZIRC image permission",
        "type" : [ "boolean", "null" ]
      }
    },
    "required" : [ "description" ],
    "type" : "object"
  },
  "uiSchema" : {
    "elements" : [ {
      "elements" : [ {
        "options" : {
          "multi" : true,
          "refreshesParent" : true
        },
        "scope" : "#/properties/description",
        "type" : "Control"
      } ],
      "type" : "Group"
    }, {
      "elements" : [ {
        "options" : {
          "widget" : "phenotypeTiming"
        },
        "scope" : "#/properties/hpfStart",
        "type" : "Control"
      } ],
      "type" : "Group"
    }, {
      "elements" : [ {
        "options" : {
          "widget" : "yesNoRadio"
        },
        "scope" : "#/properties/zfinImagePermission",
        "type" : "Control"
      }, {
        "options" : {
          "widget" : "yesNoRadio"
        },
        "scope" : "#/properties/zircImagePermission",
        "type" : "Control"
      } ],
      "type" : "Group"
    }, {
      "elements" : [ {
        "options" : {
          "noOther" : true,
          "standardValues" : [ "Mendelian recessive", "Mendelian dominant", "Non-Mendelian" ],
          "widget" : "checkboxGroup"
        },
        "scope" : "#/properties/segregation",
        "type" : "Control"
      }, {
        "options" : {
          "suffix" : "%"
        },
        "rule" : {
          "condition" : {
            "schema" : {
              "contains" : {
                "const" : "Non-Mendelian"
              }
            },
            "scope" : "#/properties/segregation"
          },
          "effect" : "SHOW"
        },
        "scope" : "#/properties/nonMendelianPercentage",
        "type" : "Control"
      }, {
        "options" : {
          "multi" : true
        },
        "rule" : {
          "condition" : {
            "schema" : {
              "contains" : {
                "const" : "Non-Mendelian"
              }
            },
            "scope" : "#/properties/segregation"
          },
          "effect" : "SHOW"
        },
        "scope" : "#/properties/nonMendelianComment",
        "type" : "Control"
      } ],
      "type" : "Group"
    }, {
      "elements" : [ {
        "options" : {
          "standardValues" : [ "Zygotic (Z)", "Maternal (M)", "Maternal-Zygotic (M-Z)" ],
          "widget" : "checkboxGroup"
        },
        "scope" : "#/properties/type",
        "type" : "Control"
      } ],
      "type" : "Group"
    } ],
    "type" : "VerticalLayout"
  }
}
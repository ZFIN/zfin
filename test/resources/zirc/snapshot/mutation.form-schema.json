{
  "schema" : {
    "properties" : {
      "alleleDesignation" : {
        "maxLength" : 255,
        "title" : "Allele Designation",
        "type" : "string"
      },
      "alleleInZfin" : {
        "title" : "Allele already in ZFIN",
        "type" : [ "boolean", "null" ]
      },
      "assays" : {
        "items" : {
          "properties" : {
            "assayType" : {
              "type" : [ "string", "null" ]
            },
            "id" : {
              "type" : "number"
            },
            "sortOrder" : {
              "type" : "number"
            }
          },
          "type" : "object"
        },
        "maxItems" : 10,
        "title" : "Genotyping Assays",
        "type" : "array"
      },
      "genes" : {
        "items" : {
          "properties" : {
            "id" : {
              "type" : "number"
            },
            "mutatedGeneAbbreviation" : {
              "type" : [ "string", "null" ]
            },
            "mutatedGeneZdbID" : {
              "type" : [ "string", "null" ]
            },
            "sortOrder" : {
              "type" : "number"
            }
          },
          "type" : "object"
        },
        "maxItems" : 10,
        "title" : "Genes",
        "type" : "array"
      },
      "homozygousLethal" : {
        "title" : "Homozygous Lethal",
        "type" : [ "boolean", "null" ]
      },
      "lesions" : {
        "items" : {
          "properties" : {
            "id" : {
              "type" : "number"
            },
            "lesionType" : {
              "type" : [ "string", "null" ]
            },
            "sortOrder" : {
              "type" : "number"
            }
          },
          "type" : "object"
        },
        "maxItems" : 10,
        "title" : "Lesions",
        "type" : "array"
      },
      "lethalityAdditionalInfo" : {
        "maxLength" : 5000,
        "title" : "Lethality Additional Info",
        "type" : "string"
      },
      "lethalitySpecificTimepoint" : {
        "maxLength" : 255,
        "title" : "Specific Timepoint",
        "type" : "string"
      },
      "lethalityStageTypical" : {
        "maxLength" : 255,
        "title" : "Typical Lethality Stage",
        "type" : "string"
      },
      "lethalityWindowEnd" : {
        "maxLength" : 255,
        "title" : "Lethality Window End",
        "type" : "string"
      },
      "lethalityWindowStart" : {
        "maxLength" : 255,
        "title" : "Lethality Window Start",
        "type" : "string"
      },
      "molecularlyCharacterized" : {
        "title" : "Molecularly Characterized",
        "type" : [ "boolean", "null" ]
      },
      "mutagenesisProtocol" : {
        "maxLength" : 255,
        "title" : "Mutagenesis Protocol",
        "type" : "string"
      },
      "mutagenesisStage" : {
        "maxLength" : 255,
        "title" : "Mutagenesis Stage",
        "type" : "string"
      },
      "mutationDiscoverer" : {
        "maxLength" : 255,
        "title" : "Discoverer",
        "type" : "string"
      },
      "mutationInstitution" : {
        "maxLength" : 255,
        "title" : "Institution",
        "type" : "string"
      },
      "mutationType" : {
        "maxLength" : 255,
        "title" : "Mutation Type",
        "type" : "string"
      },
      "phenotypes" : {
        "items" : {
          "properties" : {
            "description" : {
              "type" : [ "string", "null" ]
            },
            "id" : {
              "type" : "number"
            },
            "sortOrder" : {
              "type" : "number"
            }
          },
          "type" : "object"
        },
        "maxItems" : 10,
        "title" : "Phenotypes",
        "type" : "array"
      },
      "publications" : {
        "items" : {
          "type" : "string"
        },
        "title" : "Publications",
        "type" : "array"
      }
    },
    "type" : "object"
  },
  "uiSchema" : {
    "elements" : [ {
      "elements" : [ {
        "options" : {
          "helpText" : "ZFIN allele designation; leave blank if not yet assigned.",
          "placeholder" : "e.g. zf123"
        },
        "scope" : "#/properties/alleleDesignation",
        "type" : "Control"
      }, {
        "options" : {
          "widget" : "yesNoRadio"
        },
        "scope" : "#/properties/alleleInZfin",
        "type" : "Control"
      }, {
        "scope" : "#/properties/mutationType",
        "type" : "Control"
      }, {
        "options" : {
          "placeholder" : "Person who first identified the mutation"
        },
        "scope" : "#/properties/mutationDiscoverer",
        "type" : "Control"
      }, {
        "options" : {
          "placeholder" : "Lab / institution"
        },
        "scope" : "#/properties/mutationInstitution",
        "type" : "Control"
      } ],
      "label" : "General",
      "type" : "Group"
    }, {
      "elements" : [ {
        "options" : {
          "standardValues" : [ "oocyte", "sperm", "embryo", "larva", "adult", "unknown" ],
          "widget" : "selectWithOther"
        },
        "scope" : "#/properties/mutagenesisStage",
        "type" : "Control"
      }, {
        "options" : {
          "standardValues" : [ "ENU", "CRISPR/Cas9", "TALEN", "ZFN", "ionizing radiation", "spontaneous" ],
          "widget" : "selectWithOther"
        },
        "scope" : "#/properties/mutagenesisProtocol",
        "type" : "Control"
      }, {
        "options" : {
          "widget" : "yesNoRadio"
        },
        "scope" : "#/properties/molecularlyCharacterized",
        "type" : "Control"
      } ],
      "label" : "Mutagenesis",
      "type" : "Group"
    }, {
      "elements" : [ {
        "options" : {
          "widget" : "yesNoRadio"
        },
        "scope" : "#/properties/homozygousLethal",
        "type" : "Control"
      }, {
        "options" : {
          "standardValues" : [ "embryonic", "larval", "juvenile", "adult", "unknown" ],
          "widget" : "selectWithOther"
        },
        "rule" : {
          "condition" : {
            "schema" : {
              "const" : true
            },
            "scope" : "#/properties/homozygousLethal"
          },
          "effect" : "SHOW"
        },
        "scope" : "#/properties/lethalityStageTypical",
        "type" : "Control"
      }, {
        "options" : {
          "helpText" : "Single timepoint when most homozygotes die. Use the window fields below for a range.",
          "placeholder" : "e.g. 48 hpf"
        },
        "rule" : {
          "condition" : {
            "schema" : {
              "const" : true
            },
            "scope" : "#/properties/homozygousLethal"
          },
          "effect" : "SHOW"
        },
        "scope" : "#/properties/lethalitySpecificTimepoint",
        "type" : "Control"
      }, {
        "options" : {
          "placeholder" : "e.g. 24 hpf"
        },
        "rule" : {
          "condition" : {
            "schema" : {
              "const" : true
            },
            "scope" : "#/properties/homozygousLethal"
          },
          "effect" : "SHOW"
        },
        "scope" : "#/properties/lethalityWindowStart",
        "type" : "Control"
      }, {
        "options" : {
          "placeholder" : "e.g. 72 hpf"
        },
        "rule" : {
          "condition" : {
            "schema" : {
              "const" : true
            },
            "scope" : "#/properties/homozygousLethal"
          },
          "effect" : "SHOW"
        },
        "scope" : "#/properties/lethalityWindowEnd",
        "type" : "Control"
      }, {
        "options" : {
          "multi" : true
        },
        "rule" : {
          "condition" : {
            "schema" : {
              "const" : true
            },
            "scope" : "#/properties/homozygousLethal"
          },
          "effect" : "SHOW"
        },
        "scope" : "#/properties/lethalityAdditionalInfo",
        "type" : "Control"
      } ],
      "label" : "Lethality",
      "type" : "Group"
    }, {
      "elements" : [ {
        "options" : {
          "widget" : "stringList"
        },
        "scope" : "#/properties/publications",
        "type" : "Control"
      } ],
      "label" : "Publications",
      "type" : "Group"
    }, {
      "elements" : [ {
        "options" : {
          "widget" : "assaysList"
        },
        "scope" : "#/properties/assays",
        "type" : "Control"
      } ],
      "label" : "Genotyping Assays",
      "options" : {
        "layout" : "plain"
      },
      "type" : "Group"
    }, {
      "elements" : [ {
        "options" : {
          "widget" : "genesList"
        },
        "scope" : "#/properties/genes",
        "type" : "Control"
      } ],
      "label" : "Genes",
      "options" : {
        "layout" : "plain"
      },
      "type" : "Group"
    }, {
      "elements" : [ {
        "options" : {
          "widget" : "lesionsList"
        },
        "scope" : "#/properties/lesions",
        "type" : "Control"
      } ],
      "label" : "Lesions",
      "options" : {
        "layout" : "plain"
      },
      "type" : "Group"
    }, {
      "elements" : [ {
        "options" : {
          "widget" : "phenotypesList"
        },
        "scope" : "#/properties/phenotypes",
        "type" : "Control"
      } ],
      "label" : "Phenotypes",
      "options" : {
        "layout" : "plain"
      },
      "type" : "Group"
    } ],
    "type" : "VerticalLayout"
  }
}
    "categories": {
      "LOAD":    { "label": "Load",    "icon": "✅", "order": 1, "description": "These accessions will be loaded." },
      "DELETE":  { "label": "Delete",  "icon": "🗑",  "order": 2, "description": "These accessions will be dropped from a gene." },
      "ERROR":   { "label": "Error",   "icon": "❌", "order": 3, "description": "These accessions are marked as having errors and will not be loaded." },
      "WARNING": { "label": "Warning", "icon": "⚠️", "order": 4, "description": "Warnings only — these will not block the load." },
      "INFO":    { "label": "Info",    "icon": "ℹ️",  "order": 5, "description": "Informational entries; no load action taken." }
    }
  },


<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <!--
        ZIRC line submission schema.
        Source ER diagram: image-20260327-204843.png.
        Schema review notes: ZFIN-10162 (Ryan Taylor, 2026-04-27 meeting).

        All tables live in the dedicated PostgreSQL schema `zirc`. Cross-zirc FKs are
        qualified (e.g. zirc.line_submission). FKs out to existing ZFIN tables
        (zdb_active_data, person, marker) live in public — left unqualified, resolved via
        search_path.

        Naming convention: every column is prefixed with the first letters of each word in
        the table name (line_submission -> ls_, line_submission_linked_feature -> lslf_,
        genotyping_assay -> ga_). Single-word tables get the first letter (m_, g_, l_, p_).

        Decisions applied (per ZFIN-10162):
          - line_submission ↔ person association (zirc.line_submission_person)
          - ls_name globally unique (revisit if multi-submitter same-name is desired)
          - linked-feature distance metadata moved per-feature
          - dropped the "unreported_features" gate; keep only ls_unreported_features_details
          - g_mutated_gene FK'd to public.marker(mrkr_zdb_id)
          - g_linkage_group is varchar(10) since "NT" is a valid value
          - p_segregation / p_type are native text[] columns (replaced child tables)
          - long-text columns are TEXT (no varchar caps)
          - typo fix: l_index_insertion_size
          - PKs are bigint IDENTITY (auto-generated). Cleaner cross-DB joins than UUIDs and
            smaller indexes; not wired into ZFIN's zdb_active_data infrastructure.
          - all submission-internal FKs ON DELETE CASCADE; FKs to person/marker are RESTRICT

        Still open (pending mockup review):
          - sister "_other" columns wherever a form field offers "Other"
          - status column (pending/approved/rejected) and updated_at trigger
          - versioning / history / comments table
    -->
    <changeSet author="cmpich" id="ZIRC-line-submission">

        <sql>CREATE SCHEMA IF NOT EXISTS zirc;</sql>

        <!-- Root table. ls_id is a UUID; not tied into zdb_active_data. -->
        <createTable schemaName="zirc" tableName="line_submission">
            <column name="ls_id" type="bigint" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="ls_name" type="varchar(255)">
                <constraints unique="true" uniqueConstraintName="line_submission_name_unique"/>
            </column>
            <column name="ls_abbreviation" type="varchar(255)"/>
            <column name="ls_previous_names" type="varchar(255)"/>
            <column name="ls_features_linked" type="boolean"/>
            <column name="ls_maternal_background" type="varchar(255)"/>
            <column name="ls_paternal_background" type="varchar(255)"/>
            <column name="ls_background_changeable" type="boolean"/>
            <column name="ls_background_change_concerns" type="text"/>
            <column name="ls_unreported_features_details" type="text"/>
            <column name="ls_additional_info" type="text"/>
            <column name="ls_created_at" type="timestamp" defaultValueComputed="now()">
                <constraints nullable="false"/>
            </column>
            <column name="ls_updated_at" type="timestamp" defaultValueComputed="now()">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <!-- Submitters / contacts / PIs / contributors -->
        <createTable schemaName="zirc" tableName="line_submission_person">
            <column name="lsp_line_submission_id" type="bigint">
                <constraints nullable="false"
                             foreignKeyName="fk_line_submission_person_submission"
                             references="zirc.line_submission(ls_id)"
                             deleteCascade="true"/>
            </column>
            <column name="lsp_person_zdb_id" type="text">
                <constraints nullable="false"
                             foreignKeyName="fk_line_submission_person_person"
                             references="person(zdb_id)"/>
            </column>
            <column name="lsp_role" type="varchar(50)">
                <constraints nullable="false"/>
            </column>
            <column name="lsp_sort_order" type="integer">
                <constraints nullable="false"/>
            </column>
            <column name="lsp_created_at" type="timestamp" defaultValueComputed="now()">
                <constraints nullable="false"/>
            </column>
        </createTable>
        <addPrimaryKey schemaName="zirc"
                       tableName="line_submission_person"
                       columnNames="lsp_line_submission_id, lsp_person_zdb_id, lsp_role"
                       constraintName="line_submission_person_pk"/>

        <!-- Multi-row child of line_submission: acceptance reasons -->
        <createTable schemaName="zirc" tableName="line_submission_reason">
            <column name="lsr_line_submission_id" type="bigint">
                <constraints nullable="false"
                             foreignKeyName="fk_line_submission_reason_parent"
                             references="zirc.line_submission(ls_id)"
                             deleteCascade="true"/>
            </column>
            <column name="lsr_reason" type="varchar(255)">
                <constraints nullable="false"/>
            </column>
            <column name="lsr_sort_order" type="integer">
                <constraints nullable="false"/>
            </column>
        </createTable>
        <addPrimaryKey schemaName="zirc"
                       tableName="line_submission_reason"
                       columnNames="lsr_line_submission_id, lsr_sort_order"
                       constraintName="line_submission_reason_pk"/>

        <!-- Linked features: distance metadata is per-feature, not on the root -->
        <createTable schemaName="zirc" tableName="line_submission_linked_feature">
            <column name="lslf_line_submission_id" type="bigint">
                <constraints nullable="false"
                             foreignKeyName="fk_line_submission_linked_feature_parent"
                             references="zirc.line_submission(ls_id)"
                             deleteCascade="true"/>
            </column>
            <column name="lslf_feature" type="varchar(255)">
                <constraints nullable="false"/>
            </column>
            <column name="lslf_distance_known" type="boolean"/>
            <column name="lslf_distance_centimorgans" type="double precision"/>
            <column name="lslf_distance_megabases" type="double precision"/>
            <column name="lslf_additional_info" type="text"/>
        </createTable>
        <addPrimaryKey schemaName="zirc"
                       tableName="line_submission_linked_feature"
                       columnNames="lslf_line_submission_id, lslf_feature"
                       constraintName="line_submission_linked_feature_pk"/>

        <!-- Mutation: per-line, has its own children -->
        <createTable schemaName="zirc" tableName="mutation">
            <column name="m_id" type="bigint" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="m_line_submission_id" type="bigint">
                <constraints nullable="false"
                             foreignKeyName="fk_mutation_line_submission"
                             references="zirc.line_submission(ls_id)"
                             deleteCascade="true"/>
            </column>
            <column name="m_sort_order" type="integer">
                <constraints nullable="false"/>
            </column>
            <column name="m_allele_designation" type="varchar(255)"/>
            <column name="m_mutagenesis_protocol" type="varchar(255)"/>
            <column name="m_molecularly_characterized" type="boolean"/>
            <column name="m_mutation_type" type="varchar(255)"/>
            <column name="m_homozygous_lethal" type="boolean"/>
            <column name="m_lethality_stage_typical" type="varchar(255)"/>
            <column name="m_lethality_specific_timepoint" type="varchar(255)"/>
            <column name="m_lethality_window_start" type="varchar(255)"/>
            <column name="m_lethality_window_end" type="varchar(255)"/>
            <column name="m_lethality_additional_info" type="text"/>
            <column name="m_zfin_record_established" type="boolean"/>
            <column name="m_cell_genomic_feature" type="varchar(255)"/>
            <column name="m_mutation_discoverer" type="varchar(255)"/>
            <column name="m_mutation_institution" type="varchar(255)"/>
        </createTable>

        <!-- Multi-row child of mutation -->
        <createTable schemaName="zirc" tableName="mutation_publication">
            <column name="mp_mutation_id" type="bigint">
                <constraints nullable="false"
                             foreignKeyName="fk_mutation_publication_parent"
                             references="zirc.mutation(m_id)"
                             deleteCascade="true"/>
            </column>
            <column name="mp_publication" type="varchar(255)">
                <constraints nullable="false"/>
            </column>
            <column name="mp_sort_order" type="integer">
                <constraints nullable="false"/>
            </column>
        </createTable>
        <addPrimaryKey schemaName="zirc"
                       tableName="mutation_publication"
                       columnNames="mp_mutation_id, mp_sort_order"
                       constraintName="mutation_publication_pk"/>

        <!-- Per-mutation single-row children -->
        <createTable schemaName="zirc" tableName="gene">
            <column name="g_id" type="bigint" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="g_mutation_id" type="bigint">
                <constraints nullable="false"
                             foreignKeyName="fk_gene_mutation"
                             references="zirc.mutation(m_id)"
                             deleteCascade="true"/>
            </column>
            <column name="g_sort_order" type="integer">
                <constraints nullable="false"/>
            </column>
            <column name="g_mutated_gene" type="text">
                <constraints foreignKeyName="fk_gene_mutated_gene_marker"
                             references="marker(mrkr_zdb_id)"/>
            </column>
            <column name="g_linkage_group" type="varchar(10)"/>
            <column name="g_genbank_genomic_dna" type="varchar(255)"/>
            <column name="g_genbank_cdna" type="varchar(255)"/>
        </createTable>

        <createTable schemaName="zirc" tableName="lesion">
            <column name="l_id" type="bigint" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="l_mutation_id" type="bigint">
                <constraints nullable="false"
                             foreignKeyName="fk_lesion_mutation"
                             references="zirc.mutation(m_id)"
                             deleteCascade="true"/>
            </column>
            <column name="l_sort_order" type="integer">
                <constraints nullable="false"/>
            </column>
            <column name="l_lesion_type" type="varchar(255)"/>
            <column name="l_index_deletion_pos" type="integer"/>
            <column name="l_index_insertion_size" type="integer"/>
            <column name="l_deleted_base_pairs" type="text"/>
            <column name="l_inserted_base_pairs" type="text"/>
            <column name="l_wt_genomic_sequence" type="text"/>
            <column name="l_mutated_amino_acids" type="text"/>
            <column name="l_additional_info" type="text"/>
        </createTable>

        <createTable schemaName="zirc" tableName="genotyping_assay">
            <column name="ga_id" type="bigint" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="ga_mutation_id" type="bigint">
                <constraints nullable="false"
                             foreignKeyName="fk_genotyping_assay_mutation"
                             references="zirc.mutation(m_id)"
                             deleteCascade="true"/>
            </column>
            <column name="ga_sort_order" type="integer">
                <constraints nullable="false"/>
            </column>
            <column name="ga_assay_type" type="varchar(255)"/>
            <column name="ga_forward_primer" type="text"/>
            <column name="ga_reverse_primer" type="text"/>
            <column name="ga_expected_wt_pcr" type="text"/>
            <column name="ga_expected_mut_pcr" type="text"/>
            <column name="ga_restriction_enzyme" type="varchar(255)"/>
            <column name="ga_enzyme_cleaves" type="varchar(255)"/>
            <column name="ga_expected_wt_digest" type="text"/>
            <column name="ga_expected_mut_digest" type="text"/>
            <column name="ga_additional_info" type="text"/>
        </createTable>

        <!-- Phenotype: p_segregation and p_type are native text[] arrays. -->
        <createTable schemaName="zirc" tableName="phenotype">
            <column name="p_id" type="bigint" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="p_mutation_id" type="bigint">
                <constraints nullable="false"
                             foreignKeyName="fk_phenotype_mutation"
                             references="zirc.mutation(m_id)"
                             deleteCascade="true"/>
            </column>
            <column name="p_sort_order" type="integer">
                <constraints nullable="false"/>
            </column>
            <column name="p_description" type="text"/>
            <column name="p_hours_post_fertilization" type="integer"/>
            <column name="p_stage" type="varchar(255)"/>
            <column name="p_zfin_image_permission" type="boolean"/>
            <column name="p_non_mendelian_percentage" type="double precision"/>
            <column name="p_segregation" type="text[]"/>
            <column name="p_type" type="text[]"/>
        </createTable>

        <!-- Indexes on FKs that aren't already the leading PK column -->
        <createIndex schemaName="zirc" tableName="mutation" indexName="mutation_line_submission_idx">
            <column name="m_line_submission_id"/>
        </createIndex>
        <createIndex schemaName="zirc" tableName="gene" indexName="gene_mutation_idx">
            <column name="g_mutation_id"/>
        </createIndex>
        <createIndex schemaName="zirc" tableName="gene" indexName="gene_mutated_gene_idx">
            <column name="g_mutated_gene"/>
        </createIndex>
        <createIndex schemaName="zirc" tableName="lesion" indexName="lesion_mutation_idx">
            <column name="l_mutation_id"/>
        </createIndex>
        <createIndex schemaName="zirc" tableName="genotyping_assay" indexName="genotyping_assay_mutation_idx">
            <column name="ga_mutation_id"/>
        </createIndex>
        <createIndex schemaName="zirc" tableName="phenotype" indexName="phenotype_mutation_idx">
            <column name="p_mutation_id"/>
        </createIndex>
        <createIndex schemaName="zirc" tableName="line_submission_person" indexName="line_submission_person_person_idx">
            <column name="lsp_person_zdb_id"/>
        </createIndex>

    </changeSet>

</databaseChangeLog>
